# All text files use LF in the working tree. This repo is deployed on Linux
# VMs (gateway is Debian); CRLF in shell scripts makes `#!/usr/bin/env bash`
# fail with "/usr/bin/env: 'bash\r': No such file or directory" because the
# kernel reads the carriage return as part of the interpreter name.
#
# Forcing LF here overrides per-user core.autocrlf settings on Windows hosts.

* text=auto eol=lf

# Files that must always be LF regardless of `text=auto` heuristics.
*.sh        text eol=lf
*.py        text eol=lf
*.j2        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.toml      text eol=lf
*.nft       text eol=lf
*.sql       text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.conf      text eol=lf
*.md        text eol=lf

# Binary — never mess with these
*.png       binary
*.jpg       binary
*.ico       binary
*.svg       text eol=lf
