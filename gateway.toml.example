# Gateway configuration. Copy to gateway.toml and edit before running install.sh.
# Most values are immutable post-install (changing them requires re-running the
# installer or `gateway-reconfigure`). Module toggles can be flipped at runtime
# from the panel — what's set here is just the initial state.

[gateway]
name      = "gw-isolated-01"
wan_iface = "eth0"
lan_iface = "eth1"
# Address the gateway holds on the LAN-internal bridge. CIDR form.
lan_cidr  = "192.168.100.1/24"

[modules]
wireguard  = true
tor        = false
dhcp       = true
monitoring = false

[wireguard]
listen_port = 51820
peer_cidr   = "10.66.66.0/24"
# Public reachable endpoint for peer configs. Host:port.
endpoint    = "vpn.example.com:51820"

[dhcp]
# dnsmasq dhcp-range syntax: start,end,lease-time
range = "192.168.100.100,192.168.100.200,12h"

[panel]
# Bind addresses for the custom panel and WGDashboard.
#   - Default ("10.66.66.1"): reachable only via the WG tunnel.
#   - "0.0.0.0":              reachable from every interface, gated by nft.
#                             Use this when the gateway's "WAN" is itself an
#                             internal management network (not the public
#                             internet).
bind_addr = "10.66.66.1"
bind_port = 8443
wgd_bind_addr = "10.66.66.1"
wgd_bind_port = 10086

# When true, nft also opens panel + WGDashboard ports on the WAN interface.
# Combine with bind_addr = "0.0.0.0" to make the panels reachable there.
# DO NOT set true if your WAN is the public internet.
expose_on_wan = false

[tor]
trans_port = 9040
dns_port   = 5353
