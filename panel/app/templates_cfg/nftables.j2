{# Rendered by the panel applier on every Apply.
   Replaces /etc/nftables.d/50-panel.nft.

   - Set element re-population (flush + add) for blocked_*/tor_* sets.
   - panel_forward chain rebuild with explicit ACL rules.
   - lan_egress chain rebuild with allowlist + restricted subnets.

   Two render macros centralise the proto/port matrix so we never emit
   invalid nft like `ip daddr X dport Y accept` (dport needs a proto context)
   or `ip daddr X tcp accept` (tcp without dport needs `ip protocol tcp`).
#}
# AUTOGENERATED — do not edit. Source: panel applier.

{# Sanitise proto: anything not in the known set falls back to 'any'. Stale
   rows that predate input validation can carry empty strings or NULL. #}
{%- macro safe_proto(p) -%}
{%- if p in ['tcp','udp'] -%}{{ p }}{%- else -%}any{%- endif -%}
{%- endmacro -%}

{# Render an ACL line with src_ip + dst_cidr + proto + optional dport. #}
{%- macro acl_line(src, dst, proto, dport, action) -%}
{%-   set p = safe_proto(proto) -%}
{%-   if dport -%}
{%-     if p == 'any' %}
        ip saddr {{ src }} ip daddr {{ dst }} tcp dport {{ dport }} {{ action }}
        ip saddr {{ src }} ip daddr {{ dst }} udp dport {{ dport }} {{ action }}
{%-     else %}
        ip saddr {{ src }} ip daddr {{ dst }} {{ p }} dport {{ dport }} {{ action }}
{%-     endif -%}
{%-   else -%}
{%-     if p == 'any' %}
        ip saddr {{ src }} ip daddr {{ dst }} {{ action }}
{%-     else %}
        ip saddr {{ src }} ip daddr {{ dst }} ip protocol {{ p }} {{ action }}
{%-     endif -%}
{%-   endif -%}
{%- endmacro -%}

{# Render a LAN-egress allow line with dst_cidr + proto + optional dport. #}
{%- macro egress_line(dst, proto, dport) -%}
{%-   set p = safe_proto(proto) -%}
{%-   if dport -%}
{%-     if p == 'any' %}
        ip daddr {{ dst }} tcp dport {{ dport }} accept
        ip daddr {{ dst }} udp dport {{ dport }} accept
{%-     else %}
        ip daddr {{ dst }} {{ p }} dport {{ dport }} accept
{%-     endif -%}
{%-   else -%}
{%-     if p == 'any' %}
        ip daddr {{ dst }} accept
{%-     else %}
        ip daddr {{ dst }} ip protocol {{ p }} accept
{%-     endif -%}
{%-   endif -%}
{%- endmacro -%}

flush set inet gateway blocked_peers
{% if blocked_peer_ips %}
add element inet gateway blocked_peers { {{ blocked_peer_ips | join(', ') }} }
{% endif %}

flush set inet gateway tor_peers
{% if tor_peer_ips %}
add element inet gateway tor_peers { {{ tor_peer_ips | join(', ') }} }
{% endif %}

flush set inet gateway blocked_hosts
{% if blocked_host_ips %}
add element inet gateway blocked_hosts { {{ blocked_host_ips | join(', ') }} }
{% endif %}

flush set inet gateway tor_hosts
{% if tor_host_ips %}
add element inet gateway tor_hosts { {{ tor_host_ips | join(', ') }} }
{% endif %}

flush chain inet gateway panel_forward

table inet gateway {
    chain panel_forward {
{%- for r in acls %}
{{ acl_line(r.src_ip, r.dst_cidr, r.proto, r.dport, r.action) }}
{%- endfor %}
    }
}

# --- LAN egress: per-host private-subnet restrictions -------------------------
# Allowlist evaluated FIRST. Anything not allowlisted but inside a restricted
# subnet is dropped. Anything else returns to forward and falls through to the
# broad LAN→WAN accept (i.e. internet works untouched).
flush chain inet gateway lan_egress

table inet gateway {
    chain lan_egress {
{%- for r in lan_egress_allow %}
{{ egress_line(r.dst_cidr, r.proto, r.dport) }}
{%- endfor %}
{%- for cidr in lan_restricted %}
        ip daddr {{ cidr }} drop
{%- endfor %}
    }
}
