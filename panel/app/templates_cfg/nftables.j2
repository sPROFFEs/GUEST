{# Rendered by the panel applier on every Apply.
   Replaces /etc/nftables.d/50-panel.nft.

   - Set element re-population (flush + add) for blocked_*/tor_* sets.
   - panel_forward chain rebuild with explicit ACL rules.
#}
# AUTOGENERATED — do not edit. Source: panel applier.

flush set inet gateway blocked_peers
{% if blocked_peer_ips %}
add element inet gateway blocked_peers { {{ blocked_peer_ips | join(', ') }} }
{% endif %}

flush set inet gateway tor_peers
{% if tor_peer_ips %}
add element inet gateway tor_peers { {{ tor_peer_ips | join(', ') }} }
{% endif %}

flush set inet gateway blocked_hosts
{% if blocked_host_ips %}
add element inet gateway blocked_hosts { {{ blocked_host_ips | join(', ') }} }
{% endif %}

flush set inet gateway tor_hosts
{% if tor_host_ips %}
add element inet gateway tor_hosts { {{ tor_host_ips | join(', ') }} }
{% endif %}

flush chain inet gateway panel_forward

table inet gateway {
    chain panel_forward {
{% for r in acls %}
{% if r.dport and r.proto == 'any' %}
        ip saddr {{ r.src_ip }} ip daddr {{ r.dst_cidr }} tcp dport {{ r.dport }} {{ r.action }}
        ip saddr {{ r.src_ip }} ip daddr {{ r.dst_cidr }} udp dport {{ r.dport }} {{ r.action }}
{% else %}
        ip saddr {{ r.src_ip }} ip daddr {{ r.dst_cidr }}{% if r.proto != 'any' %} {{ r.proto }}{% endif %}{% if r.dport %} dport {{ r.dport }}{% endif %} {{ r.action }}
{% endif %}
{% endfor %}
    }
}

# --- LAN egress: per-host private-subnet restrictions -------------------------
# Allowlist evaluated FIRST. Anything not allowlisted but inside a restricted
# subnet is dropped. Anything else returns to forward and falls through to the
# broad LAN→WAN accept (i.e. internet works untouched).
flush chain inet gateway lan_egress

table inet gateway {
    chain lan_egress {
{% for r in lan_egress_allow %}
{% if r.dport and r.proto == 'any' %}
        ip daddr {{ r.dst_cidr }} tcp dport {{ r.dport }} accept
        ip daddr {{ r.dst_cidr }} udp dport {{ r.dport }} accept
{% else %}
        ip daddr {{ r.dst_cidr }}{% if r.proto != 'any' %} {{ r.proto }}{% endif %}{% if r.dport %} dport {{ r.dport }}{% endif %} accept
{% endif %}
{% endfor %}
{% for cidr in lan_restricted %}
        ip daddr {{ cidr }} drop
{% endfor %}
    }
}
